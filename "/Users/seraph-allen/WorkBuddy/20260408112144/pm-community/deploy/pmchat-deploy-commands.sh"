#!/bin/bash
# PMChat 一键部署脚本 - 在服务器控制台执行
# ============================================

echo "🚀 PMChat 部署开始..."
echo ""

# 1. 安装必要软件
echo "📦 步骤1/6: 安装软件..."
apt update && apt install -y git nginx certbot python3-certbot-nginx

# 2. 创建部署目录
echo "📁 步骤2/6: 创建目录..."
mkdir -p /var/www/pmchat
cd /var/www/pmchat

# 3. 克隆代码
echo "📥 步骤3/6: 拉取代码..."
git clone https://github.com/1997zql/pmchat.git .
git checkout main || true

# 4. 设置权限
echo "🔒 步骤4/6: 设置权限..."
chown -R www-data:www-data /var/www/pmchat
chmod -R 755 /var/www/pmchat

# 5. 配置Nginx
echo "🌐 步骤5/6: 配置Nginx..."
cat > /etc/nginx/sites-available/pmchat << 'NGINX_EOF'
server {
    listen 80;
    server_name pmchat.cn www.pmchat.cn;
    
    root /var/www/pmchat;
    index index.html;
    
    gzip on;
    gzip_types text/plain text/css application/json application/javascript;
    
    location / {
        try_files $uri $uri/ /index.html;
        expires 1h;
    }
    
    location ~* \.(css|js|jpg|png|gif|ico|svg|woff)$ {
        expires 30d;
    }
}
NGINX_EOF

# 启用站点
ln -sf /etc/nginx/sites-available/pmchat /etc/nginx/sites-enabled/
rm -f /etc/nginx/sites-enabled/default
nginx -t && systemctl reload nginx

# 6. 申请SSL证书
echo "🔐 步骤6/6: 申请SSL证书..."
certbot --nginx -d pmchat.cn -d www.pmchat.cn --noninteractive --agree-tos -m admin@pmchat.cn

# 配置防火墙
ufw allow 'Nginx Full' 2>/dev/null || true

echo ""
echo "========================================"
echo "✅ 部署完成！"
echo "========================================"
echo "🌐 网站地址: https://pmchat.cn"
echo "📁 代码目录: /var/www/pmchat"
echo ""
echo "📝 初始化内容: 访问 https://pmchat.cn/init-content/init.html"
echo ""
echo "常用命令:"
echo "  更新代码: cd /var/www/pmchat && git pull"
echo "  重启Nginx: systemctl restart nginx"
echo "  查看SSL: certbot certificates"
echo "========================================"
