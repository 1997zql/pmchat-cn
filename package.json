{
  "name": "pmchat-platform",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/web",
    "apps/api",
    "packages/shared"
  ],
  "scripts": {
    "dev:web": "npm run dev -w apps/web",
    "dev:api": "npm run start:dev -w apps/api",
    "build:shared": "npm run build -w packages/shared",
    "build:web": "npm run build:shared && npm run build -w apps/web",
    "build:api": "npm run build:shared && npm run build -w apps/api",
    "start:web": "npm run start -w apps/web",
    "start:api": "npm run start -w apps/api",
    "lint:web": "npm run lint -w apps/web",
    "db:generate": "npm run prisma:generate -w apps/api",
    "db:migrate": "npm run prisma:migrate -w apps/api",
    "db:migrate:deploy": "npm run prisma:migrate:deploy -w apps/api"
  }
}
